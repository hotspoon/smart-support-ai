generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  ADMIN
  AGENT
}

enum ConversationStatus {
  OPEN
  WAITING
  RESOLVED
}

enum MessageSender {
  USER
  AI
  ADMIN
}

enum ResolutionSource {
  AI
  ADMIN
}

model Workspace {
  id            String          @id @default(cuid())
  name          String
  slug          String          @unique
  brandColor    String          @default("#10B981")
  welcomeMessage String         @default("Ada yang bisa kami bantu?") @db.Text
  businessHours String          @default("Senin–Jumat, 08.00–17.00 WIB")
  onboardingCompletedAt DateTime?
  users         User[]
  conversations Conversation[]
  knowledgeBase KnowledgeBase[]
  promptSetting PromptSetting?
  notifications Notification[]
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt
}

model User {
  id            String         @id @default(cuid())
  workspaceId   String
  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name          String
  email         String         @unique
  emailVerified Boolean        @default(false)
  role          UserRole       @default(AGENT)
  image         String?
  assigned      Conversation[] @relation("AssignedAgent")
  sessions      Session[]
  accounts      Account[]
  notifications Notification[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([workspaceId])
}

model Session {
  id        String   @id
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model Account {
  id                    String    @id
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
}

model Conversation {
  id               String             @id @default(cuid())
  workspaceId      String
  workspace        Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  assignedToId     String?
  assignedTo       User?              @relation("AssignedAgent", fields: [assignedToId], references: [id], onDelete: SetNull)
  customerName     String
  customerEmail    String?
  channel          String             @default("WEB")
  status           ConversationStatus @default(OPEN)
  subject          String?
  summary          String?
  tags             String[]
  publicTokenHash  String?            @unique
  lastMessageAt    DateTime           @default(now())
  lastCustomerMessageAt DateTime      @default(now())
  lastAgentReplyAt DateTime?
  resolutionSource ResolutionSource?
  messages         Message[]
  feedback         ConversationFeedback?
  notifications    Notification[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  resolvedAt       DateTime?

  @@index([workspaceId, status, updatedAt])
  @@index([assignedToId])
}

model Notification {
  id             String       @id @default(cuid())
  workspaceId    String
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  recipientId    String
  recipient      User         @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  lastEventAt    DateTime     @default(now())
  readAt         DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([recipientId, conversationId])
  @@index([workspaceId, lastEventAt])
  @@index([recipientId, readAt, lastEventAt])
}

model ConversationFeedback {
  id             String       @id @default(cuid())
  conversationId String       @unique
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  rating         Int
  comment        String?      @db.Text
  createdAt      DateTime     @default(now())
}

model Message {
  id              String        @id @default(cuid())
  conversationId  String
  conversation    Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          MessageSender
  content         String        @db.Text
  model           String?
  latencyMs       Int?
  inputTokens     Int?
  outputTokens    Int?
  clientMessageId String?
  createdAt       DateTime      @default(now())

  @@unique([conversationId, clientMessageId])
  @@index([conversationId, createdAt])
}

model RateLimitBucket {
  id          String   @id @default(cuid())
  key         String
  windowStart DateTime
  expiresAt   DateTime
  count       Int      @default(1)
  updatedAt   DateTime @updatedAt

  @@unique([key, windowStart])
  @@index([expiresAt])
}

model KnowledgeBase {
  id          String    @id @default(cuid())
  workspaceId String
  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  title       String
  content     String    @db.Text
  category    String    @default("Umum")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([workspaceId, isActive])
}

model PromptSetting {
  id              String    @id @default(cuid())
  workspaceId     String    @unique
  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  systemPrompt    String    @db.Text
  temperature     Float     @default(0.3)
  model           String    @default("gpt-4.1-mini")
  autoReply       Boolean   @default(true)
  maxHistory      Int       @default(10)
  fallbackToAgent Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
}
