# Neon pooled connection string (use the URL ending in -pooler for Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require"

# Server-side only. Never prefix secrets with NEXT_PUBLIC_.
AI_PROVIDER="groq"
AI_API_KEY="gsk_..."
AI_BASE_URL="https://api.groq.com/openai/v1"
AI_MODEL="llama-3.3-70b-versatile"

# Use the same value as the seeded workspace slug.
DEFAULT_WORKSPACE_SLUG="halo-shop"

# Generate both secrets independently, for example with `openssl rand -base64 32`.
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
CHAT_SESSION_SECRET=""

# Set true after the first admin has been created.
AUTH_DISABLE_SIGN_UP="false"
# Always use true in production. Server pages and APIs still validate the DB session.
AUTH_REQUIRED="true"
